# ==== Обязательные переменные ====

# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# ID администраторов через запятую (ваш Telegram user id).
# Узнать свой id можно у @userinfobot
ADMIN_IDS=123456789

# Строка подключения к PostgreSQL.
# На Railway: добавьте плагин Postgres и укажите ${{Postgres.DATABASE_URL}}.
# Локально, например: postgresql://postgres:postgres@localhost:5432/postgres
DATABASE_URL=

# ==== Опциональные переменные ====

# Публичный адрес приложения (HTTPS). На Railway можно не указывать —
# он подставится автоматически из RAILWAY_PUBLIC_DOMAIN.
# Локально/на другом хостинге укажите вручную, напр:
# WEBAPP_URL=https://your-app.up.railway.app
WEBAPP_URL=

# Порт (Railway задаёт автоматически). Локально по умолчанию 3000.
PORT=3000

# Папка для загруженных изображений (по умолчанию ./data/uploads).
# На Railway это диск сервиса web — если нужна сохранность файлов между
# передеплоями, подключите отдельный Volume и укажите путь внутри него.
UPLOADS_DIR=./data/uploads

# Включить SSL для подключения к Postgres (нужно для внешних провайдеров
# вроде Supabase/Neon; для Railway/локального Postgres не требуется).
PGSSL=0

# Разрешить вход без Telegram (ТОЛЬКО для локальной разработки!).
# В проде оставьте пустым или 0.
ALLOW_DEV_AUTH=0
